@startuml
skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #EAF4FB
skinparam classBorderColor #2980B9
skinparam classHeaderBackgroundColor #1A3A5C
skinparam classHeaderFontColor white
skinparam fontSize 13

title Class Diagram (Analysis Phase) — Vehicle Access Control System

class Owner {
  - owner_id : int
  - first_name : String
  - last_name : String
  - national_id : String
  - phone_number : String
  - department : String
  - personnel_code : String
  - is_active : Boolean
  + register() : void
  + deactivate() : void
  + getFullName() : String
}

class Vehicle {
  - vehicle_id : int
  - plate_number : String
  - brand : String
  - model : String
  - color : String
  - vehicle_type : String
  - is_active : Boolean
  - registration_date : Date
  + register() : void
  + update() : void
  + deactivate() : void
  + isActive() : Boolean
}

class Barrier {
  - barrier_id : int
  - barrier_name : String
  - location : String
  - direction : String
  - status : String
  - install_date : Date
  + register() : void
  + update() : void
  + activate() : void
  + deactivate() : void
}

class Camera {
  - camera_id : int
  - ip_address : String
  - model : String
  - status : String
  + captureImage() : Image
  + detectPlate() : String
  + activate() : void
  + deactivate() : void
}

class AccessPermission {
  - permission_id : int
  - access_type : String
  - valid_from : Date
  - valid_until : Date
  - time_from : Time
  - time_until : Time
  - is_active : Boolean
  + grant() : void
  + revoke() : void
  + isValid() : Boolean
  + checkTimeWindow() : Boolean
}

class AccessLog {
  - log_id : int
  - event_type : String
  - event_datetime : DateTime
  - detected_plate : String
  - plate_image_path : String
  - access_status : String
  - deny_reason : String
  + record() : void
  + getStatus() : String
}

class Operator {
  - operator_id : int
  - username : String
  - password_hash : String
  - full_name : String
  - role : String
  - is_active : Boolean
  + login() : Boolean
  + logout() : void
  + hasPermission() : Boolean
}

class AccessControlEngine {
  + checkAccess(plate, barrier, type) : Boolean
  + processEntry(plate, barrier) : AccessLog
  + processExit(plate, barrier) : AccessLog
}

Owner "1" o-- "N" Vehicle : owns >
Vehicle "1" *-- "N" AccessPermission : has >
Barrier "1" *-- "N" AccessPermission : controls >
Barrier "1" o-- "N" Camera : equipped with >
AccessPermission "1" *-- "N" AccessLog : generates >
Vehicle "1" *-- "N" AccessLog : recorded in >
Barrier "1" *-- "N" AccessLog : logged at >
Operator "1" ..> AccessLog : manages >
AccessControlEngine ..> AccessPermission : checks >
AccessControlEngine ..> AccessLog : creates >
AccessControlEngine ..> Camera : uses >

@enduml
